      "parameters": {
        "jsCode": "const groqResponse = $input.first().json;\nconst rawText = groqResponse?.choices?.[0]?.message?.content ?? '{}';\nconst cleaned = rawText.replace(/```json\\s*/gi, '').replace(/```\\s*/gi, '').trim();\n\n// ─── BUSINESS CONFIG ──────────────────────────────\nconst SLOT_DURATION_MIN = 30;\nconst WORK_START_HOUR = 10;    // 10:00 am\nconst WORK_END_HOUR = 18;      // last slot 18:30\nconst WORK_END_MIN = 30;\nconst VALID_SLOTS = [\n  '10:00','10:30','11:00','11:30','12:00','12:30',\n  '13:00','13:30','14:00','14:30','15:00','15:30',\n  '16:00','16:30','17:00','17:30','18:00','18:30'\n];\nconst WORK_DAYS = [1,2,3,4,5,6]; // Mon=1 ... Sat=6 (0=Sun)\n// ──────────────────────────────────────────────────\n\nlet booking;\ntry {\n  booking = JSON.parse(cleaned);\n} catch(e) {\n  booking = { date: null, time: null, duration_minutes: SLOT_DURATION_MIN, name: 'Unknown', notes: '', out_of_hours: false, is_sunday: false };\n}\n\nconst senderPhone = $('IF — Skip Non-Messages').first().json.senderPhone;\nconst phoneNumberId = $('IF — Skip Non-Messages').first().json.phoneNumberId;\nconst senderName = $('IF — Skip Non-Messages').first().json.senderName;\n\nlet startDateTime = null;\nlet endDateTime = null;\nlet isValid = false;\nlet invalidReason = null;\n\nif (booking.date && booking.time) {\n\n  // Snap time to nearest valid 30-min slot\n  const [hStr, mStr] = booking.time.split(':');\n  let h = parseInt(hStr);\n  let m = parseInt(mStr);\n  // Round to nearest 30\n  const totalMin = h * 60 + m;\n  const snappedMin = Math.round(totalMin / 30) * 30;\n  const snappedH = Math.floor(snappedMin / 60);\n  const snappedM = snappedMin % 60;\n  const snappedTime = `${String(snappedH).padStart(2,'0')}:${String(snappedM).padStart(2,'0')}`;\n\n  // Check it's a valid slot\n  const slotOk = VALID_SLOTS.includes(snappedTime);\n\n  // Check working day\n  const dateObj = new Date(`${booking.date}T${snappedTime}:00`);\n  const dayOfWeek = dateObj.getDay(); // 0=Sun\n  const dayOk = WORK_DAYS.includes(dayOfWeek);\n\n  if (!slotOk) {\n    invalidReason = 'out_of_hours';\n  } else if (!dayOk) {\n    invalidReason = 'sunday';\n  } else {\n    startDateTime = `${booking.date}T${snappedTime}:00`;\n    const endMs = new Date(startDateTime).getTime() + SLOT_DURATION_MIN * 60 * 1000;\n    endDateTime = new Date(endMs).toISOString().slice(0,19);\n    isValid = true;\n  }\n} else {\n  invalidReason = 'missing_datetime';\n}\n\nreturn [{\n  json: {\n    ...booking,\n    duration_minutes: SLOT_DURATION_MIN,\n    senderPhone,\n    phoneNumberId,\n    senderName,\n    startDateTime,\n    endDateTime,\n    isValid,\n    invalidReason\n  }\n}];"
      },
