      "parameters": {
        "jsCode": "const body = $input.first().json.body;\nconst query = $input.first().json.query;\n\n// META WEBHOOK VERIFICATION (GET request)\n// When you first set up the webhook in Meta dashboard,\n// Meta sends a GET request to verify. This handles it.\nif (query && query['hub.mode'] === 'subscribe') {\n  // Return the challenge token — Meta checks this\n  // You must set VERIFY_TOKEN to match what you enter in Meta dashboard\n  const VERIFY_TOKEN = 'my_whatsapp_verify_token_123';\n  if (query['hub.verify_token'] === VERIFY_TOKEN) {\n    return [{ json: { challenge: query['hub.challenge'], isVerification: true } }];\n  } else {\n    throw new Error('Webhook verification failed — token mismatch');\n  }\n}\n\n// NORMAL MESSAGE — extract data from Meta's nested structure\ntry {\n  const entry = body.entry?.[0];\n  const change = entry?.changes?.[0];\n  const value = change?.value;\n  const message = value?.messages?.[0];\n\n  if (!message) {\n    // Could be a status update (delivered, read) — ignore silently\n    return [{ json: { isStatusUpdate: true, skip: true } }];\n  }\n\n  const senderPhone = message.from;\n  const messageText = message.text?.body ?? '';\n  const messageId = message.id;\n  const senderName = value?.contacts?.[0]?.profile?.name ?? 'Friend';\n  const phoneNumberId = value?.metadata?.phone_number_id;\n\n  return [{\n    json: {\n      isVerification: false,\n      isStatusUpdate: false,\n      skip: false,\n      senderPhone,\n      senderName,\n      messageText,\n      messageId,\n      phoneNumberId\n    }\n  }];\n} catch (e) {\n  throw new Error('Failed to parse WhatsApp message: ' + e.message);\n}"
      },
