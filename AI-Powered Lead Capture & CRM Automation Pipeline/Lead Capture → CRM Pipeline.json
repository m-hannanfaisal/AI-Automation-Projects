    {
      "parameters": {
        "sendTo": "={{ $json.email }}",
        "subject": "=Thanks for reaching out, {{ $json.name.split(' ')[0] }}!",
        "message": "=<html><body style=\"font-family: Arial, sans-serif; color: #333; max-width: 600px; margin: 0 auto; padding: 20px;\">\n<p>Hi {{ $json.name.split(' ')[0] }},</p>\n\n<p>Thanks for getting in touch! We've received your message and someone from our team will be back to you shortly.</p>\n\n<p>Here's a quick summary of what you sent us:</p>\n\n<blockquote style=\"background: #f5f5f5; padding: 12px 16px; border-left: 4px solid #4A90E2; margin: 16px 0;\">\n  <em>\"{{ $json.message }}\"</em>\n</blockquote>\n\n<p>In the meantime, feel free to reply to this email if you have any questions.</p>\n\n<p>Talk soon,<br/>\n<strong>The Team</strong></p>\n</body></html>",
        "options": {}
      },
