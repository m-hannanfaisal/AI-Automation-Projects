    {
      "parameters": {
        "method": "POST",
        "url": "=https://api.groq.com/openai/v1/chat/completions",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"llama-3.3-70b-versatile\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are a lead qualification assistant for a sales team. You analyze incoming leads and return a JSON object only.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Analyze this lead and respond with a JSON object in this exact format:\\n{\\n  \\\"score\\\": \\\"Hot\\\" or \\\"Warm\\\" or \\\"Cold\\\",\\n  \\\"priority\\\": a number 1-10,\\n  \\\"reason\\\": \\\"One sentence explanation\\\",\\n  \\\"follow_up\\\": \\\"Suggested first message to send this lead\\\"\\n}\\n\\nLead info:\\nName: {{ $json.name }}\\nCompany: {{ $json.company }}\\nEmail: {{ $json.email }}\\nMessage: {{ $json.message }}\\nSource: {{ $json.source }}\"\n    }\n  ],\n  \"temperature\": 0.3,\n  \"max_tokens\": 300,\n  \"response_format\": { \"type\": \"json_object\" }\n}",
        "options": {}
      },
      "id": "51239612-0043-46f5-aca5-826f3e14eb5b",
      "name": "Gemini — Score Lead",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        448,
        176
      ],
      "credentials": {
        "httpQueryAuth": {
          "id": "AR2IHblruf7ubsku",
          "name": "Gemini API Key"
        },
        "httpHeaderAuth": {
          "id": "TZziUn7tAvEHQheq",
          "name": "Header Auth account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const lead = $('Set — Map & Clean Fields').first().json;\n\n// Groq (OpenAI-compatible) response structure: choices[0].message.content\n// response_format: { type: 'json_object' } guarantees this is clean JSON,\n// no markdown fences to strip — but we keep a fallback in case the call\n// itself errors or returns something unexpected.\nconst groqResponse = $input.first().json;\nconst rawText = groqResponse?.choices?.[0]?.message?.content ?? '{}';\n\nlet ai;\ntry {\n  ai = JSON.parse(rawText);\n} catch (e) {\n  ai = { score: 'Warm', priority: 5, reason: 'Could not parse AI response', follow_up: 'Follow up with a friendly intro email.' };\n}\n\nreturn [{\n  json: {\n    ...lead,\n    lead_score: ai.score,\n    lead_priority: ai.priority,\n    lead_reason: ai.reason,\n    follow_up_suggestion: ai.follow_up,\n    submitted_at: new Date().toISOString()\n  }\n}];"
      },
