      "parameters": {
        "jsCode": "const items = $input.all();\nconst sorted = items\n  .map(i => i.json)\n  .filter(c => c.finalScore !== undefined && c.finalScore !== '')\n  .sort((a, b) => Number(b.finalScore) - Number(a.finalScore));\nconst top20 = sorted.slice(0, 20);\nreturn top20.map(c => ({ json: c }));"
      },
