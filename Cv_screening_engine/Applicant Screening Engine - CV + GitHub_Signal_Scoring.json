    {
      "parameters": {
        "url": "=https://api.github.com/users/{{$('Extract GitHub Username').item.json.githubUsername}}/repos?sort=updated&per_page=10",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "githubApi",
        "options": {}
      },
      "id": "3ca35ed1-636b-4c70-b57e-9925cce95b11",
      "name": "Get GitHub Repos",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        0,
        128
      ],
      "credentials": {
        "githubApi": {
          "id": "gJWrnfkmCGVq4AJT",
          "name": "GitHub account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const profile = $('Get GitHub Profile').item.json;\nconst repos = $('Get GitHub Repos').all().map(i => i.json);\nconst candidate = $('Extract GitHub Username').item.json;\n\nconst repoCount = profile.public_repos || 0;\nconst followers = profile.followers || 0;\nconst recentlyActive = repos.some(r => {\n  const updated = new Date(r.updated_at);\n  const monthsAgo = (Date.now() - updated.getTime()) / (1000*60*60*24*30);\n  return monthsAgo < 6;\n});\nconst languages = [...new Set(repos.map(r => r.language).filter(Boolean))];\nconst hasReadmePresence = repos.some(r => r.description && r.description.length > 10);\n\nlet githubScore = 0;\nif (repoCount >= 5) githubScore += 1;\nif (recentlyActive) githubScore += 1;\nif (languages.length >= 2) githubScore += 1;\nif (followers >= 5) githubScore += 1;\nif (hasReadmePresence) githubScore += 1;\n\nreturn [{ json: { ...candidate, githubScore, githubRepoCount: repoCount, githubLanguages: languages, githubRecentlyActive: recentlyActive } }];"
      },
      "id": "19bef102-57ff-4afa-8b8a-ad2f3dfde9b3",
      "name": "Compute GitHub Signal Score",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        224,
        64
      ]
    },
    {
      "parameters": {
        "jsCode": "return [{ json: { ...$json, githubScore: 0, githubRepoCount: 0, githubLanguages: [], githubRecentlyActive: false } }];"
      },
