      "parameters": {
        "jsCode": "const items = $input.all();\nreturn items.map(item => {\n  let parsed = { score: 0, reasoning: 'parse error' };\n  try {\n    parsed = JSON.parse(item.json.choices[0].message.content);\n  } catch (e) {}\n  return { json: { ...item.json, finalScore: parsed.score, scoreReasoning: parsed.reasoning } };\n});"
