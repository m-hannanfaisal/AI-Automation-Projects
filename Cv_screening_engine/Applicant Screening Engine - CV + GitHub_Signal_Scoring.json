    {
      "parameters": {
        "jsCode": "const url = $json.githubUrl || '';\nconst match = url.match(/github\\.com\\/([A-Za-z0-9-]+)/);\nreturn [{ json: { ...$json, githubUsername: match ? match[1] : null } }];"
      },
      "id": "5fe139e2-c4e7-472f-b92e-0d29086ce800",
      "name": "Extract GitHub Username",
