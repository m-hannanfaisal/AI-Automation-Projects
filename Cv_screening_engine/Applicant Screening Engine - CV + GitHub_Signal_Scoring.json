    {
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/chat/completions",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "openAiApi",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"gpt-4o-mini\",\n  \"response_format\": { \"type\": \"json_object\" },\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"Extract structured candidate data from this CV text. Return strict JSON with keys: name, email, phone, yearsExperience (number), skills (array of strings), education (string), githubUrl (string or null), linkedinUrl (string or null), summary (one sentence).\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"={{$json.text}}\"\n    }\n  ]\n}",
        "options": {}
      },
      "id": "3bc1191d-5a4c-42ca-bc0b-762eab7b8a63",
      "name": "AI Extract CV Fields",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -880,
        144
      ],
      "credentials": {
        "openAiApi": {
          "id": "QNOIcLMW7cMGjMl5",
          "name": "OpenAI account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nreturn items.map(item => {\n  let parsed = {};\n  try {\n    parsed = JSON.parse(item.json.choices[0].message.content);\n  } catch (e) {\n    parsed = { name: 'unknown', skills: [], yearsExperience: 0 };\n  }\n  return { json: parsed };\n});"
      },
      "id": "89c435a5-4679-4999-b5f1-a72876afc06d",
