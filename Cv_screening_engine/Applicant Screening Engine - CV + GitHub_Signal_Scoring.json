    {
      "parameters": {
        "jsCode": "const items = $input.all();\nlet rows = items.map(i => `<tr><td>${i.json.name}</td><td>${i.json.finalScore}</td><td>${i.json.skills}</td><td>${i.json.yearsExperience}</td><td>${i.json.reasoning}</td><td><a href=\"${i.json.githubUrl||''}\">GitHub</a> / <a href=\"${i.json.linkedinUrl||''}\">LinkedIn</a></td></tr>`).join('');\nconst html = `<p>Top ${items.length} candidates this run. This is a screening aid only — please review before making any decisions.</p><table border=\"1\" cellpadding=\"6\"><tr><th>Name</th><th>Score</th><th>Skills</th><th>Years Exp</th><th>Reasoning</th><th>Links</th></tr>${rows}</table>`;\nreturn [{ json: { html, count: items.length } }];"
      },
