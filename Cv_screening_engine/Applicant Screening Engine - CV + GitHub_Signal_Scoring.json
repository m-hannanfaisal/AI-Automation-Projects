        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "openAiApi",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"gpt-4o-mini\",\n  \"response_format\": { \"type\": \"json_object\" },\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You score job candidates 0-10 for fit against this role: Backend Engineer, 3+ years, Node.js/Python, cloud infra experience preferred. Score components: skills match to role (0-4), years of relevant experience (0-3), GitHub signal already provided (0-3, use the githubScore value directly scaled, e.g. githubScore of 5 = 3 points). Return strict JSON: {\\\"score\\\": <0-10 integer>, \\\"reasoning\\\": \\\"<one sentence explaining the score, mention specific skills or gaps>\\\"}. Be explicit this is a screening aid, not a final decision.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"=Name: {{$json.name}}\\nSkills: {{$json.skills}}\\nYears Experience: {{$json.yearsExperience}}\\nEducation: {{$json.education}}\\nGitHub Score: {{$json.githubScore}}\\nGitHub Languages: {{$json.githubLanguages}}\\nSummary: {{$json.summary}}\"\n    }\n  ]\n}",
        "options": {}
      },
