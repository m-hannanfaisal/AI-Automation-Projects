    {
      "parameters": {
        "jsCode": "const existing = $('Read Existing Leads').all().map(i => `${(i.json.company||'').toLowerCase().trim()}|${(i.json.title||'').toLowerCase().trim()}`);\nconst existingSet = new Set(existing);\nconst newItems = [];\nfor (const item of $input.all()) {\n  const key = `${(item.json.company||'').toLowerCase().trim()}|${(item.json.title||'').toLowerCase().trim()}`;\n  if (!existingSet.has(key)) {\n    newItems.push(item);\n  }\n}\nreturn newItems;"
      },
