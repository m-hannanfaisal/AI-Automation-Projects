        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"gpt-4o-mini\",\n  \"response_format\": { \"type\": \"json_object\" },\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You score job postings 0-5 for how strongly they signal a company needs observability/monitoring tooling. Score criteria: +1 if posting mentions on-call rotation or incident response burden. +1 if no specific observability tool (Datadog, New Relic, Grafana, Prometheus, etc) is named, suggesting greenfield need. +1 if company size signals mid-size or larger (not an early-stage 2-person startup). +1 if role is Lead/Manager/Head level (budget authority). +1 if posting explicitly mentions scaling infrastructure or reliability goals. Return strict JSON: {\\\"score\\\": <0-5 integer>, \\\"reasoning\\\": \\\"<one sentence>\\\"}\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Company: {{$json.company}}\\nTitle: {{$json.title}}\\nDescription: {{$json.description}}\"\n    }\n  ]\n}",
        "options": {}
      },
