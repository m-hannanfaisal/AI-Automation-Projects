    {
      "parameters": {
        "jsCode": "const today = new Date().toISOString().slice(0,10);\nconst todays = $input.all().filter(i => i.json.qualifiedDate === today);\nif (todays.length === 0) {\n  return [{ json: { html: '<p>No qualified leads today.</p>', count: 0 } }];\n}\nlet rows = todays.map(i => `<tr><td>${i.json.company}</td><td>${i.json.title}</td><td>${i.json.score}</td><td>${i.json.reasoning}</td><td><a href=\"${i.json.jobUrl}\">link</a></td></tr>`).join('');\nconst html = `<table border=\"1\" cellpadding=\"6\"><tr><th>Company</th><th>Title</th><th>Score</th><th>Reasoning</th><th>Link</th></tr>${rows}</table>`;\nreturn [{ json: { html, count: todays.length } }];"
      },
